# --- Site ---
SITE_URL=https://3dprinterqueue.com
SITE_NAME=Print Queue
ENV=production
LOG_LEVEL=INFO

# --- Secrets ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database (set automatically inside docker-compose) ---
DATABASE_URL=postgresql+asyncpg://printq:printq@db:5432/printq

# --- Auth allowlists ---
ALLOWED_EMAILS=anthony.echeman@spacex.com
OPERATOR_EMAILS=anthony.echeman@spacex.com

# --- Resend ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Print Queue <noreply@3dprinterqueue.com>

# --- Sentry (optional) ---
SENTRY_DSN=

# --- File storage ---
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=100
FILE_RETENTION_DAYS=90

# --- Postgres (compose only) ---
POSTGRES_USER=printq
# Generate a strong password the same way as SESSION_SECRET
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=printq

# --- Cloudflare Tunnel ---
# Paste the connector token from the Cloudflare Zero Trust dashboard.
# Networks -> Tunnels -> your tunnel -> Install Connector -> token after --token.
CLOUDFLARE_TUNNEL_TOKEN=eyJh...

# --- Backups to R2 (optional, can stay blank for now) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=print-queue-backups

# --- Bridge service ---
# Shared secret that the bridge presents to the app on /internal/telemetry.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BRIDGE_SHARED_TOKEN=change-me-shared-bridge-token

# How long without telemetry before a printer is marked OFFLINE (seconds).
PRINTER_STALE_SECONDS=30

# --- Notifications (optional) ---
# Print FAILURES are pushed to whichever of these you set. Leave blank to
# disable that channel. Submitters always get email on status changes
# (controlled per-user via the email_notifications flag).
# Slack: create an Incoming Webhook at api.slack.com/apps -> your app ->
#   Incoming Webhooks. URL looks like https://hooks.slack.com/services/...
SLACK_WEBHOOK_URL=
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook ->
#   Copy URL. Looks like https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_URL=

# --- Printers (repeat 1..N for each printer) ---
# Slug is the short identifier shown in the UI and used in URLs.
PRINTER_1_SLUG=P1
PRINTER_1_NAME=Bambu H2D #1
# Printer's IP on guest WiFi.
PRINTER_1_HOST=192.168.1.100
PRINTER_1_PORT=8883
# Find in printer's Settings -> Network info. 8-character serial.
PRINTER_1_SERIAL=00M00A000000000
# 8-digit access code from the printer screen: Settings -> Network -> Access Code.
PRINTER_1_ACCESS_CODE=12345678

PRINTER_2_SLUG=P2
PRINTER_2_NAME=Bambu H2D #2
PRINTER_2_HOST=192.168.1.101
PRINTER_2_PORT=8883
PRINTER_2_SERIAL=00M00A000000001
PRINTER_2_ACCESS_CODE=12345678
